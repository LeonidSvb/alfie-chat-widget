{
    "flow_id": "trip_planning",
    "flow_name": "planning", 
    "description": "I know my destination — help with recs & itinerary",
    "total_questions": 26,
    "alfie_triggers": [5, 10, 15, 20],
    "questions": [
        {
            "id": "Q0",
            "text": "Trip structure",
            "type": "single_select",
            "field": "trip_structure",
            "options": [
                "Single destination",
                "Multi-destination",
                "Roadtrip"
            ],
            "branches": {
                "Single destination": "Q12A",
                "Multi-destination": "Q12B",
                "Roadtrip": "Q12C"
            }
        },
        {
            "id": "Q12A",
            "text": "What's your home base?",
            "type": "free_form",
            "field": "destination_main",
            "placeholder": "Kyoto",
            "conditional": {
                "field": "trip_structure",
                "equals": "Single destination"
            }
        },
        {
            "id": "Q13A",
            "text": "Where are you staying?",
            "type": "free_form",
            "field": "stay_details",
            "placeholder": "Downtown ryokan, 4 nights",
            "conditional": {
                "field": "trip_structure",
                "equals": "Single destination"
            }
        },
        {
            "id": "Q12B",
            "text": "List your stops with nights",
            "type": "free_form",
            "field": "stops",
            "placeholder": "Florence 3 → Siena 2 → Rome 4",
            "conditional": {
                "field": "trip_structure",
                "equals": "Multi-destination"
            }
        },
        {
            "id": "Q13B",
            "text": "How do you plan to get around?",
            "type": "single_select",
            "field": "intercity_transport",
            "options": [
                "Train/Public",
                "Rental car/Self-drive",
                "Mix",
                "Not sure yet"
            ],
            "conditional": {
                "field": "trip_structure",
                "equals": "Multi-destination"
            }
        },
        {
            "id": "Q12C",
            "text": "What general area are you covering?",
            "type": "free_form",
            "field": "roadtrip_region",
            "placeholder": "Southwest loop: Vegas to the parks",
            "conditional": {
                "field": "trip_structure",
                "equals": "Roadtrip"
            }
        },
        {
            "id": "Q13C",
            "text": "Where do you start and finish?",
            "type": "free_form",
            "field": "roadtrip_start_end",
            "placeholder": "Start Vegas, end Phoenix",
            "conditional": {
                "field": "trip_structure",
                "equals": "Roadtrip"
            }
        },
        {
            "id": "Q14C",
            "text": "Max drive time per day?",
            "type": "free_form",
            "field": "max_drive_hours",
            "placeholder": "4 hours/day",
            "conditional": {
                "field": "trip_structure",
                "equals": "Roadtrip"
            }
        },
        {
            "id": "Q15C",
            "text": "Must-see stops on the route?",
            "type": "free_form",
            "field": "roadtrip_musts",
            "placeholder": "Horseshoe Bend, Monument Valley",
            "conditional": {
                "field": "trip_structure",
                "equals": "Roadtrip"
            }
        },
        {
            "id": "Q16C",
            "text": "Overnight rhythm",
            "type": "single_select",
            "field": "overnight_rhythm",
            "options": [
                "2–3 nights minimum per stop",
                "OK with 1-night stays where it makes sense"
            ],
            "conditional": {
                "field": "trip_structure",
                "equals": "Roadtrip"
            }
        },
        {
            "id": "Q1",
            "text": "When's this happening?",
            "type": "free_form",
            "field": "season_window",
            "placeholder": "Late May 2025"
        },
        {
            "id": "Q2",
            "text": "How many days total?",
            "type": "free_form",
            "field": "trip_length_days",
            "placeholder": "7 days"
        },
        {
            "id": "Q2a",
            "text": "Have you already booked accommodation?",
            "type": "single_select",
            "field": "lodging_booked",
            "options": [
                "Yes",
                "No, I need recommendations"
            ],
            "branches": {
                "Yes": "Q3",
                "No, I need recommendations": "Q2b"
            }
        },
        {
            "id": "Q2b",
            "text": "What type of stay are you leaning toward?",
            "type": "single_select",
            "field": "lodging_type",
            "options": [
                "Camping",
                "Chain hotel/Resort",
                "Boutique/Guesthouse",
                "Airbnb/Apartment",
                "B&B/Farm stay",
                "RV/Campervan"
            ],
            "conditional": {
                "field": "lodging_booked",
                "equals": "No, I need recommendations"
            }
        },
        {
            "id": "Q2c",
            "text": "What's your ballpark budget per night?",
            "type": "free_form",
            "field": "lodging_budget",
            "placeholder": "$150–200/night",
            "conditional": {
                "field": "lodging_booked",
                "equals": "No, I need recommendations"
            }
        },
        {
            "id": "Q3",
            "text": "Who is going?",
            "type": "single_select",
            "field": "party_type",
            "options": [
                "Friends",
                "Couple",
                "Solo",
                "Family <12",
                "Family 12–18",
                "Multi-gen",
                "Colleagues"
            ],
            "branches": {
                "Solo": "Q3b_solo",
                "Couple": "Q3b_solo"
            }
        },
        {
            "id": "Q3a",
            "text": "Headcount/occasion",
            "type": "free_form",
            "field": "party_details",
            "placeholder": "6 people, family reunion",
            "conditional": {
                "field": "party_type",
                "not_equals": ["Couple", "Solo"]
            }
        },
        {
            "id": "Q3b_group",
            "text": "How active is the crew overall?",
            "type": "free_form",
            "field": "group_ability",
            "placeholder": "Most can do 5–7 mile hikes; one prefers easy walks",
            "conditional": {
                "field": "party_type",
                "not_equals": ["Couple", "Solo"]
            }
        },
        {
            "id": "Q3b_solo",
            "text": "How active do you want your days to feel?",
            "type": "free_form",
            "field": "solo_activity_pref",
            "placeholder": "Happy with long hikes most days",
            "conditional": {
                "field": "party_type",
                "equals_any": ["Couple", "Solo"]
            }
        },
        {
            "id": "Q4",
            "text": "How active do you want the trip to feel?",
            "type": "single_select",
            "field": "fitness_level",
            "options": [
                "Low-key",
                "Moderate",
                "High"
            ]
        },
        {
            "id": "Q5",
            "text": "Outdoors vs culture balance",
            "type": "single_select",
            "field": "balance_ratio",
            "options": [
                "70% Outdoors / 30% Culture",
                "50% Outdoors / 50% Culture",
                "30% Outdoors / 70% Culture"
            ]
        },
        {
            "id": "Q6",
            "text": "Travel style",
            "type": "single_select",
            "field": "travel_style",
            "options": [
                "Luxe & Leisure",
                "Balanced Mix",
                "Active Explorer"
            ]
        },
        {
            "id": "Q7",
            "text": "Activities you love",
            "type": "multi_select",
            "field": "activities",
            "options": [
                "Hiking",
                "Biking",
                "Beaches & swimming",
                "Surfing",
                "Water activities",
                "Skiing/Snowboarding",
                "Scenic drives",
                "Wildlife viewing",
                "Family-friendly outdoor activities",
                "Other"
            ]
        },
        {
            "id": "Q8",
            "text": "Food preferences",
            "type": "multi_select",
            "field": "food_prefs",
            "options": [
                "Adventurous eats",
                "Super local/traditional spots",
                "Fine dining",
                "Cooking classes",
                "Food tours",
                "Markets"
            ]
        },
        {
            "id": "Q9",
            "text": "Guided or independent?",
            "type": "multi_select",
            "field": "guided_prefs",
            "options": [
                "Guided outdoor activities",
                "Guided day trips",
                "Guided city/cultural tours",
                "Food/wine tours, cooking classes",
                "No thanks — fully independent"
            ]
        },
        {
            "id": "Q10",
            "text": "Any must-dos?",
            "type": "free_form",
            "field": "must_haves",
            "placeholder": "Sunset at Grand Canyon, local cooking class"
        },
        {
            "id": "Q11",
            "text": "Any hard no's?",
            "type": "free_form",
            "field": "dealbreakers",
            "placeholder": "No crowds, avoid touristy spots"
        }
    ]
}