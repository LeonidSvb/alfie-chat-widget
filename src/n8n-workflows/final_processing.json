      "typeVersion": 2,
      "position": [800, 300],
      "credentials": {
        "airtableTokenApi": {
          "id": "TlvcaDmp0On83I0S",
          "name": "Airtable Personal Access Token account"
        }
      }
    },
    {
      "parameters": {
        "resource": "chat",
        "operation": "create",
        "model": "gpt-4o-mini",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are Alfie, the adventure concierge fox. Create final travel recommendations combining destination analysis, web research, and local expert matches. Be warm, witty, and actionable. Include specific next steps and expert contact info."
            },
            {
              "role": "user",
              "content": "Create final recommendations based on: Destinations: {{ JSON.parse($('Analyze Travel Preferences').first().json.choices[0].message.content) }} Research: {{ $('Search Destination Info').first().json.choices[0].message.content }} Experts: {{ JSON.stringify($('Find Local Experts').all()) }}"
            }
          ]
        },
        "options": {
          "temperature": 0.8,
          "maxTokens": 800
        }
      },
      "id": "generate-recommendations",
      "name": "Generate Final Recommendations",
      "type": "n8n-nodes-base.openAi", 
      "typeVersion": 1,
      "position": [1000, 300],
      "credentials": {
        "openAiApi": {
          "id": "PVUGFR4BRcDcdsZt",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "{{ {\"success\": true, \"recommendations\": $('Generate Final Recommendations').first().json.choices[0].message.content, \"destinations\": JSON.parse($('Analyze Travel Preferences').first().json.choices[0].message.content), \"experts\": $('Find Local Experts').all(), \"timestamp\": $now.toISOString()} }}"
      },
      "id": "final-response",
      "name": "Final Response",
      "type": "n8n-nodes-base.respondToWebhook",
