          "values": [
            {
              "role": "system",
              "content": "You are an expert travel analyst. Analyze the user's travel preferences and suggest 2-3 outdoor destinations. Return JSON format: {\"destinations\": [{\"name\": \"Location\", \"activities\": [\"activity1\", \"activity2\"], \"why_perfect\": \"reason\"}], \"search_queries\": [\"query1\", \"query2\"]}"
            },
            {
              "role": "user", 
              "content": "Travel preferences: {{ JSON.stringify($json.answers || {}) }}"
            }
          ]
        },
        "options": {
          "temperature": 0.7,
          "maxTokens": 500
        }
      },
      "id": "analyze-preferences",
      "name": "Analyze Travel Preferences",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [400, 300],
      "credentials": {
        "openAiApi": {
          "id": "PVUGFR4BRcDcdsZt",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.perplexity.ai/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer 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"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "llama-3.1-sonar-small-128k-online"
            },
            {
              "name": "messages",
              "value": "[{\"role\": \"system\", \"content\": \"Search for outdoor travel information. Focus on authentic local sources, avoid booking sites like Booking.com, Expedia. Prefer: AllTrails, National Park Service, local tourism boards, Outside Magazine, adventure blogs.\"}, {\"role\": \"user\", \"content\": \"{{ JSON.parse($('Analyze Travel Preferences').first().json.choices[0].message.content).search_queries[0] || 'outdoor adventures' }}\"}]"
            }
          ]
        }
      },
      "id": "search-destinations",
      "name": "Search Destination Info",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [600, 300]
    },
    {
      "parameters": {
        "operation": "list",
