{
    "flow_name": "planning",
    "description": "I know my destination — help with recs & itinerary",
    "total_questions": 11,
    "alfie_triggers": [3, 6, 9],
    "questions": [
        {
            "id": "Q0",
            "text": "Okay, start me off — what kind of trip is this?",
            "type": "single_select",
            "field": "trip_structure",
            "options": [
                "🏠 Single destination (one home base, can include day trips)",
                "🧳 Multi‑destination (changing locations/lodging)",
                "🚙 Roadtrip"
            ]
        },
        {
            "id": "Q12A",
            "text": "Where are you basing yourself?",
            "type": "free_form",
            "field": "destination_main",
            "placeholder": "Kyoto",
            "conditional": {
                "field": "trip_structure",
                "equals": "🏠 Single destination (one home base, can include day trips)"
            }
        },
        {
            "id": "Q13A",
            "text": "Got a neighborhood, hotel, or town locked in?",
            "type": "free_form", 
            "field": "stay_details",
            "placeholder": "Downtown ryokan, 4 nights",
            "conditional": {
                "field": "trip_structure",
                "equals": "🏠 Single destination (one home base, can include day trips)"
            }
        },
        {
            "id": "Q12B",
            "text": "Drop your stops in order with how many nights in each.",
            "type": "free_form",
            "field": "stops",
            "placeholder": "Florence 3 → Siena 2 → Rome 4",
            "conditional": {
                "field": "trip_structure",
                "equals": "🧳 Multi‑destination (changing locations/lodging)"
            }
        },
        {
            "id": "Q13B",
            "text": "How do you plan to get around?",
            "type": "single_select",
            "field": "intercity_transport",
            "options": [
                "🚆 Train / Public transport",
                "🚗 Rental car / Self‑drive", 
                "🔀 Mix",
                "❓ Not sure yet"
            ],
            "conditional": {
                "field": "trip_structure",
                "equals": "🧳 Multi‑destination (changing locations/lodging)"
            }
        },
        {
            "id": "Q12C",
            "text": "Paint me the broad strokes — what region are we driving?",
            "type": "free_form",
            "field": "roadtrip_region",
            "placeholder": "Southwest loop: Vegas to the parks",
            "conditional": {
                "field": "trip_structure",
                "equals": "🚙 Roadtrip"
            }
        },
        {
            "id": "Q13C",
            "text": "Same start and end, or one‑way?",
            "type": "free_form",
            "field": "roadtrip_start_end",
            "placeholder": "Start Vegas, end Phoenix",
            "conditional": {
                "field": "trip_structure",
                "equals": "🚙 Roadtrip"
            }
        },
        {
            "id": "Q1",
            "text": "Got dates, or even just a season?",
            "type": "free_form",
            "field": "season_window",
            "placeholder": "Late May 2025"
        },
        {
            "id": "Q2",
            "text": "So I know how to pace things — how many days do you have start to finish?",
            "type": "free_form",
            "field": "trip_length_days", 
            "placeholder": "7 days"
        },
        {
            "id": "Q2a",
            "text": "Have you already booked your accommodation?",
            "type": "single_select",
            "field": "lodging_booked",
            "options": [
                "✅ Yes",
                "❌ No, I need recommendations"
            ]
        },
        {
            "id": "Q2b",
            "text": "What type of stay are you leaning toward?",
            "type": "single_select",
            "field": "lodging_type",
            "options": [
                "🏕️ Camping",
                "🏨 Chain hotel / Resort",
                "🏛️ Boutique hotel / Guesthouse",
                "🏠 Airbnb / Apartment rental",
                "🏡 B&B / Farm stay",
                "🚐 RV / Campervan"
            ],
            "conditional": {
                "field": "lodging_booked",
                "equals": "❌ No, I need recommendations"
            }
        },
        {
            "id": "Q3",
            "text": "Who is going?",
            "type": "single_select",
            "field": "party_type",
            "options": [
                "👫 Friends",
                "💑 Couple",
                "🧳 Solo", 
                "👨‍👩‍👧‍👦 Family with young kids (under 12)",
                "👨‍👩‍👦‍👦 Family with kids 12–18",
                "👵👴 Multi‑gen family",
                "💼 Work trip / Colleagues"
            ]
        },
        {
            "id": "Q3a",
            "text": "Headcount/occasion",
            "type": "free_form",
            "field": "party_details",
            "placeholder": "6 people, family reunion",
            "conditional": {
                "field": "party_type",
                "not_equals": ["💑 Couple", "🧳 Solo"]
            }
        },
        {
            "id": "Q3b",
            "text": "How active is the crew overall?",
            "type": "free_form",
            "field": "group_ability",
            "placeholder": "Most can do 5–7 mile hikes; one prefers easy walks",
            "conditional": {
                "field": "party_type",
                "not_equals": ["💑 Couple", "🧳 Solo"]
            }
        },
        {
            "id": "Q3b_solo",
            "text": "How active do you want your days to feel?",
            "type": "free_form",
            "field": "solo_activity_pref", 
            "placeholder": "Happy with long hikes most days",
            "conditional": {
                "field": "party_type",
                "equals_any": ["💑 Couple", "🧳 Solo"]
            }
        },
        {
            "id": "Q4",
            "text": "How active do you want the trip to feel?",
            "type": "single_select",
            "field": "fitness_level",
            "options": [
                "🚶 Low-key",
                "🥾 Moderate", 
                "⛰️ High"
            ]
        },
        {
            "id": "Q5",
            "text": "Outdoors vs culture balance",
            "type": "single_select",
            "field": "balance_ratio",
            "options": [
                "70% Outdoors / 30% Culture",
                "50% Outdoors / 50% Culture",
                "30% Outdoors / 70% Culture"
            ]
        },
        {
            "id": "Q10",
            "text": "Any must-dos?",
            "type": "free_form",
            "field": "must_haves",
            "placeholder": "Sunset at Grand Canyon, local cooking class"
        },
        {
            "id": "Q11",
            "text": "Any hard no's?",
            "type": "free_form",
            "field": "dealbreakers",
            "placeholder": "No crowds, avoid touristy spots"
        }
    ]
}